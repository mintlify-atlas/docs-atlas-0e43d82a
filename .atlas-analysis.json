  "keyFeatures": [
    "Multiple Minecraft instance management",
    "Mod platform integration (Modrinth, CurseForge, ATLauncher, FTB, Technic)",
    "Modpack import and export",
    "Java version management and auto-download",
    "Resource pack and shader management",
    "World management",
    "Microsoft account authentication",
    "Custom launch configurations",
    "Cross-platform support (Windows, Linux, macOS)",
    "Automatic updates"
  ],
  "publicApiSurface": [
    "BaseInstance - Core instance abstraction",
    "MinecraftInstance - Minecraft-specific instance implementation",
    "PackProfile - Mod and component management",
    "InstanceList - Instance collection management",
    "ModFolderModel - Mod file management",
    "ResourcePackFolderModel - Resource pack management",
    "WorldList - World management",
    "AccountList - Account management",
    "ModAPI (Modrinth, CurseForge, etc.) - Mod platform integrations",
    "LaunchController - Launch process orchestration",
    "Application - Main application class",
    "SettingsObject - Configuration management"
  ]
